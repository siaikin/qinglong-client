{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "website/content/docs/reference",
  "readme": "none",
  "name": "qinglong-client API",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "sort": ["source-order"],
  "navigation": {
    "includeCategories": true,
    "compactFolders": true
  },
  "categorizeByGroup": true,
  "categoryOrder": [
    "Client",
    "API",
    "Types",
    "Enums",
    "*"
  ],
  "plugin": [
    "typedoc-plugin-markdown",
    "typedoc-plugin-frontmatter"
  ],
  "entryFileName": "index",
  "hidePageHeader": true,
  "hideBreadcrumbs": true,
  "useHTMLAnchors": false,
  "frontmatterGlobals": {
    "description": "从源码 JSDoc 自动生成"
  },
  "indexFrontmatter": {
    "title": "TypeDoc"
  },
  "searchInComments": true,
  "validation": {
    "notExported": false
  }
}
