{
  "name": "qinglong-client",
  "version": "1.1.0",
  "description": "TypeScript client for Qinglong Open API (/open/*)",
  "author": "siaikin <abc1310054026@outlook.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siaikin/qinglong-client.git"
  },
  "bugs": {
    "url": "https://github.com/siaikin/qinglong-client/issues"
  },
  "homepage": "https://github.com/siaikin/qinglong-client#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "docs:site": "node scripts/build-docs-site.mjs",
    "semantic-release": "semantic-release"
  },
  "packageManager": "pnpm@9.15.0",
  "keywords": [
    "qinglong",
    "client",
    "typescript",
    "open-api"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "qinglongVersion": "2.20.2",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.4",
    "@semantic-release/npm": "^13.1.0",
    "semantic-release": "^25.0.0",
    "tsup": "^8.4.0",
    "typedoc": "^0.28.0",
    "typescript": "^5.2.2"
  }
}
